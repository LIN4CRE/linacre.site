{
  "buildCommand": "npm run build",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).(png|jpg|jpeg|webp|svg|ico|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(sitemap.xml|robots.txt)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400" }
      ]
    },
    {
      "source": "/dashboard",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https://play.pokemonshowdown.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.openai.com https://api.anthropic.com; worker-src 'self' blob:; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server.ts" },
    { "source": "/", "destination": "/index.html" },
    { "source": "/projects", "destination": "/projects/index.html" },
    { "source": "/about", "destination": "/about/index.html" },
    { "source": "/toolkit", "destination": "/toolkit/index.html" },
    { "source": "/learn", "destination": "/learn/index.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/blog/go-concurrency-patterns", "destination": "/blog/go-concurrency-patterns/index.html" },
    { "source": "/blog/dynamic-hsl-theme-variables", "destination": "/blog/dynamic-hsl-theme-variables/index.html" },
    { "source": "/blog/optimizing-edge-cdn-caching", "destination": "/blog/optimizing-edge-cdn-caching/index.html" },
    { "source": "/playground", "destination": "/playground/index.html" },
    { "source": "/contact", "destination": "/contact/index.html" },
    { "source": "/privacy", "destination": "/privacy/index.html" },
    { "source": "/accessibility", "destination": "/accessibility/index.html" },
    { "source": "/dashboard", "destination": "/index.html" }
  ]
}
